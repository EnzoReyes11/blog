---
type Props = {
  title: string;
  full_screen?: boolean;
  className?: string;
  titleHref?: string;
};
const { title = "Section", full_screen = false, className = "", titleHref } = Astro.props;
---

<section
  id={title.toLowerCase().replaceAll(" ", "")}
  class={`${full_screen ? "h-screen" : ""} px-4 py-10 w-screen !overflow-x-hidden ${className}`}
>
  <div class="w-full grid place-items-center">
    {titleHref ? (
      <a href={titleHref} class="hover:underline underline-offset-8">
        <h2 class="text-4xl md:text-6xl text-center">{`<${title} />`}</h2>
      </a>
    ) : (
      <h2 class="text-4xl md:text-6xl text-center">{`<${title} />`}</h2>
    )}
  </div>
  <div class="w-full mt-10 px-4">
    <slot />
  </div>
</section>
