---
import Layout from '../layouts/Layout.astro';
import { SITE, CONTACT } from '../consts';
import { strings } from '../i18n';

const { home } = strings;
---

<Layout title={SITE.title} description={SITE.description} currentPage="home" fullFooter={true}>

  <!-- Hero Section -->
  <div class="brutal-label">{home.heroLabel}</div>
  <div class="brutal-card text-left grid md:grid-cols-2 gap-8 items-center">
    <div>
      <ul class="space-y-6">
        {home.heroItems.map((item) => (
          <li class="flex gap-4 items-start">
            <div class="w-6 h-6 text-brand shrink-0 border-2 border-black p-1 bg-white flex items-center justify-center">
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m3 3 7.07 16.97 2.51-7.39 7.39-2.51L3 3z"/><path d="m13 13 6 6"/></svg>
            </div>
            <span class="font-bold">{item}</span>
          </li>
        ))}
      </ul>
    </div>
    <div class="bg-slate-100 border-2 border-black p-4 flex items-center justify-center aspect-video shadow-[4px_4px_0px_0px_rgba(0,0,0,1)]">
      <img src="https://picsum.photos/seed/automation/500/300" alt="Automatización Ilustración" class="border-2 border-black" referrerpolicy="no-referrer" />
    </div>
  </div>

  <!-- Benefits Section -->
  <div class="brutal-label">{home.whyLabel}</div>
  <div class="grid md:grid-cols-2 gap-8 mb-12">
    <div class="brutal-card m-0 p-8 flex gap-6 items-start text-left">
      <div class="bg-yellow-300 border-2 border-black p-2 shrink-0 shadow-[2px_2px_0px_0px_rgba(0,0,0,1)] flex items-center justify-center">
        <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="16" height="16" x="4" y="4" rx="2"/><rect width="6" height="6" x="9" y="9" rx="1"/><path d="M15 2v2"/><path d="M15 20v2"/><path d="M20 15h2"/><path d="M2 15h2"/><path d="M9 2v2"/><path d="M9 20v2"/><path d="M20 9h2"/><path d="M2 9h2"/></svg>
      </div>
      <div>
        <h3 class="font-black text-xl mb-2 underline decoration-brand decoration-4 underline-offset-4">{home.whyCards[0].title}</h3>
        <p class="font-bold text-slate-700">{home.whyCards[0].body}</p>
      </div>
    </div>
    <div class="brutal-card m-0 p-8 flex gap-6 items-start text-left">
      <div class="bg-green-300 border-2 border-black p-2 shrink-0 shadow-[2px_2px_0px_0px_rgba(0,0,0,1)] flex items-center justify-center">
        <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 14l8-10v8l8-10v12l-8 10v-8l-8 10z"/></svg>
      </div>
      <div>
        <h3 class="font-black text-xl mb-2 underline decoration-brand decoration-4 underline-offset-4">{home.whyCards[1].title}</h3>
        <p class="font-bold text-slate-700">{home.whyCards[1].body}</p>
      </div>
    </div>
  </div>

  <!-- Services grid -->
  <div class="brutal-label" id="servicios">{home.servicesLabel}</div>
  <div class="brutal-card p-0 overflow-hidden mb-12 shadow-[8px_8px_0px_0px_rgba(0,0,0,1)]">
    <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 border-l-2 border-t-2 border-black">
      {home.serviceItems.map((item) => (
        <div class="brutal-grid-item">{item}</div>
      ))}
    </div>
    <div class="p-4 bg-yellow-100 border-t-2 border-black text-xs font-black text-black uppercase tracking-[0.2em]">
      {home.servicesFooter}
    </div>
  </div>

  <!-- Contact info -->
  <div class="brutal-label" id="contact">{home.contactLabel}</div>
  <div class="brutal-card text-left grid md:grid-cols-2 gap-12 items-center">
    <div>
      <h3 class="text-2xl font-black mb-6 uppercase">{home.contactHeading}</h3>
      <div class="space-y-6">
        <div class="flex items-center gap-4">
          <div class="bg-brand border-2 border-black p-1 shadow-[2px_2px_0px_0px_rgba(0,0,0,1)] flex items-center justify-center">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-white"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
          </div>
          <span class="font-black text-lg">{CONTACT.email}</span>
        </div>
        <a href={CONTACT.whatsappUrl} target="_blank" rel="noopener" class="flex items-center gap-4 hover:opacity-80 transition-opacity">
          <div class="bg-green-500 border-2 border-black p-1 shadow-[2px_2px_0px_0px_rgba(0,0,0,1)] flex items-center justify-center">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="white"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
          </div>
          <span class="font-black text-lg">{CONTACT.phone}</span>
        </a>
        <div class="flex items-center gap-4">
          <div class="bg-brand border-2 border-black p-1 shadow-[2px_2px_0px_0px_rgba(0,0,0,1)] flex items-center justify-center">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-white"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/></svg>
          </div>
          <span class="font-black text-lg">{CONTACT.location}</span>
        </div>
      </div>

      <div class="flex flex-col sm:flex-row gap-4 mt-10">
        <a href={CONTACT.calendarUrl} target="_blank" rel="noopener" class="brutal-button inline-block text-center">
          {home.calendarBtn}
        </a>
        <a href={CONTACT.whatsappUrl} target="_blank" rel="noopener" class="inline-block px-8 py-3 bg-green-500 text-white font-black border-2 border-black text-center transition-all hover:-translate-y-0.5 hover:-translate-x-0.5 active:translate-y-0 active:translate-x-0" style="box-shadow: 4px 4px 0px 0px rgba(0,0,0,1)">
          {home.whatsappBtn}
        </a>
      </div>
    </div>
    <div class="bg-yellow-100 border-2 border-black p-8 flex flex-col items-center justify-center text-center shadow-[4px_4px_0px_0px_rgba(0,0,0,1)]">
      <div class="w-32 h-32 border-4 border-black shadow-[4px_4px_0px_0px_rgba(0,0,0,1)] overflow-hidden mb-6 bg-white">
        <img src="/assets/profile.jpg" alt="Enzo Reyes" class="w-full h-full object-cover object-top" />
      </div>
      <p class="font-black text-xl mb-1 uppercase">Enzo Reyes</p>
      <p class="text-xs font-black text-brand uppercase tracking-widest bg-white border border-black px-2 py-0.5">{home.role}</p>
    </div>
  </div>

</Layout>
